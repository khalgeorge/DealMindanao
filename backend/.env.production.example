# =============================================================================
# DealMindanao — PRODUCTION Environment Template
# =============================================================================
# Copy this file to .env on your production server:
#   cp .env.production.example .env
#
# Then fill in every value marked with <CHANGE_THIS>.
# Never commit the real .env file to git.
# =============================================================================

APP_NAME="DealMindanao"
APP_ENV=production
APP_KEY=<RUN: php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://dealmindanao.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logging — only record real errors in production
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---------------------------------------------------------------------------
# Database — use strong credentials, NOT the dev defaults
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=<YOUR_DB_HOST>         # e.g. 127.0.0.1 or your managed DB hostname
DB_PORT=3306
DB_DATABASE=dealmindanao
DB_USERNAME=<YOUR_DB_USER>
DB_PASSWORD=<YOUR_STRONG_DB_PASSWORD>

# ---------------------------------------------------------------------------
# Session — encrypted, HTTPS-only cookies
# ---------------------------------------------------------------------------
SESSION_DRIVER=database         # switch from file to database for reliability
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.dealmindanao.com
SESSION_SECURE_COOKIE=true      # HTTPS only
SESSION_SAME_SITE=lax

# ---------------------------------------------------------------------------
# CORS — only allow your real production frontend origin
# ---------------------------------------------------------------------------
FRONTEND_URL=https://dealmindanao.com

# ---------------------------------------------------------------------------
# Broadcasting / Queue / Cache
# ---------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database       # run: php artisan queue:work (via Supervisor)

CACHE_STORE=file                # upgrade to redis if you have it available

# ---------------------------------------------------------------------------
# Redis (optional but recommended for cache + sessions)
# ---------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail — same credentials as dev (already configured with Gmail)
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=george.badoles@gmail.com
MAIL_PASSWORD=<YOUR_GMAIL_APP_PASSWORD>
MAIL_FROM_ADDRESS="hello@dealmindanao.com"
MAIL_FROM_NAME="DealMindanao"

# ---------------------------------------------------------------------------
# Laravel Passport — run: php artisan passport:keys  (generates these)
# ---------------------------------------------------------------------------
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# ---------------------------------------------------------------------------
# AWS S3 (optional — for cloud image storage)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# Google reCAPTCHA v3 — already registered, same keys are fine
# Get/manage at: https://www.google.com/recaptcha/admin
# Make sure your production domain is added to the allowed domains list there
# ---------------------------------------------------------------------------
RECAPTCHA_SITE_KEY=6LcC7HUsAAAAAO2cPbUek8_aGlEb2BuoV8SqB3jo
RECAPTCHA_SECRET_KEY=6LcC7HUsAAAAABW2xwA_FRQQMdQFhzEuHAzKlPt2

# ---------------------------------------------------------------------------
# Facebook Messenger Chat Widget
# ---------------------------------------------------------------------------
FACEBOOK_PAGE_ID=960240460512198
